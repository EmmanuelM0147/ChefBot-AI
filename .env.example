GEMINI_API_KEY="your-gemini-api-key"

# Host-side / Option B defaults (apps on the host, deps in Docker)
QDRANT_URL="http://localhost:6333"
QDRANT_API_KEY=""
CHEFBOT_API_URL="http://localhost:8000"
DATABASE_URL="postgresql://user:password@localhost:5433/chefbot_monitoring"

# Optional: hosted full recipe dump for prepare_dataset.py
# CHEFBOT_DATASET_URL="https://YOUR-HOST/recipes.jsonl"

# Full docker compose (Option A) overrides DATABASE_URL + QDRANT_URL to
# service DNS (postgres / qdrant) and sets CHEFBOT_API_URL=http://api:8000
# inside the UI container. You only need GEMINI_API_KEY in .env for that path.

# Production monitoring (preferred: Supabase / Neon / Vercel Postgres — not Render).
# Use the connection pooler URI when available. SSL is added automatically for remote hosts.
# Example Supabase transaction pooler:
# DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres"

# Production Qdrant Cloud (optional; compose local Qdrant is the default)
# QDRANT_URL="https://YOUR-CLUSTER.aws.cloud.qdrant.io"
# QDRANT_API_KEY="your-qdrant-api-key"

CORS_ORIGINS="https://chefbot-ai-9v272ty2jahksxappfpvhqg.streamlit.app,http://localhost:8501,http://127.0.0.1:8501"
